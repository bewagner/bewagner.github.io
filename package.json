{
  "name": "zolarwind",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "css:build": "npx tailwindcss -i ./css/main.css -o ./static/css/generated.css --minify",
    "css:watch": "npx tailwindcss -i ./css/main.css -o ./static/css/generated.css --watch",
    "js:build": "npx esbuild src/trailsolver.js --bundle --outfile=static/js/trailsolver.js --format=esm --platform=browser --define:global=globalThis --define:process.env.NODE_ENV=\\\"production\\\"",
    "js:copy-z3": "cp node_modules/z3-solver/build/z3-built.js static/js/z3-built.js && cp node_modules/z3-solver/build/z3-built.wasm static/js/z3-built.wasm",
    "server": "zola serve"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "4",
    "esbuild": "latest",
    "tailwindcss": "4"
  },
  "dependencies": {
    "z3-solver": "latest"
  }
}
